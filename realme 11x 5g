<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPS Device Tracker - Bus Station Simulation</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #0f172a;
            color: #f8fafc;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 480px;
            background: #1e293b;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            border: 1px solid #334155;
        }

        .header {
            background: #0284c7;
            padding: 20px;
            text-align: center;
        }

        .header h2 {
            font-size: 22px;
            color: #ffffff;
            margin-bottom: 5px;
        }

        .header p {
            font-size: 13px;
            color: #e0f2fe;
        }

        .content {
            padding: 20px;
        }

        .card {
            background: #0f172a;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 15px;
            border: 1px solid #334155;
        }

        .row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            font-size: 15px;
        }

        .row:last-child {
            margin-bottom: 0;
        }

        .label {
            color: #94a3b8;
            font-weight: 500;
        }

        .value {
            color: #f1f5f9;
            font-weight: 600;
            text-align: right;
        }

        /* एक्टिव स्टेटस (हरे रंग में) */
        .status-active {
            background-color: rgba(34, 197, 94, 0.15);
            color: #22c55e;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: bold;
            border: 1px solid rgba(34, 197, 94, 0.4);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .status-active::before {
            content: '';
            width: 8px;
            height: 8px;
            background-color: #22c55e;
            border-radius: 50%;
            box-shadow: 0 0 8px #22c55e;
        }

        /* डीएक्टिव स्टेटस */
        .status-deactive {
            background-color: rgba(239, 68, 68, 0.15);
            color: #ef4444;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: bold;
            border: 1px solid rgba(239, 68, 68, 0.4);
        }

        .map-box {
            width: 100%;
            height: 150px;
            background: #334155;
            border-radius: 8px;
            margin-top: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #94a3b8;
            font-size: 14px;
            position: relative;
            overflow: hidden;
        }

        .radar-pulse {
            position: absolute;
            width: 30px;
            height: 30px;
            background: rgba(34, 197, 94, 0.4);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% {
                transform: scale(0.5);
                opacity: 1;
            }
            100% {
                transform: scale(3.5);
                opacity: 0;
            }
        }

        .footer {
            text-align: center;
            padding: 12px;
            background: #111827;
            font-size: 12px;
            color: #64748b;
            border-top: 1px solid #334155;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <h2>GPS Live Tracker</h2>
            <p>Bus Station Surveillance System</p>
        </div>

        <div class="content">
            <!-- डिवाइस और नंबर की जानकारी -->
            <div class="card">
                <div class="row">
                    <span class="label">Mobile Name:</span>
                    <span class="value" id="deviceName">Samsung Galaxy S24</span>
                </div>
                <div class="row">
                    <span class="label">Phone Number:</span>
                    <span class="value" id="phoneNumber">+977 982066XXXX</span>
                </div>
                <div class="row">
                    <span class="label">Status:</span>
                    <span class="value">
                        <!-- एक्टिव स्टेटस हरे रंग में -->
                        <span class="status-active" id="deviceStatus">Active</span>
                    </span>
                </div>
            </div>

            <!-- लोकेशन की जानकारी -->
            <div class="card">
                <div class="row">
                    <span class="label">Location:</span>
                    <span class="value" id="locationName">Bus Station, Gate No. 2</span>
                </div>
                <div class="row">
                    <span class="label">Coordinates:</span>
                    <span class="value" id="coordinates">27.1750° N, 84.8631° E</span>
                </div>
                <div class="row">
                    <span class="label">Signal:</span>
                    <span class="value" style="color: #38bdf8;">Strong (4G LTE)</span>
                </div>

                <!-- फ़ेक मैप सिमुलेशन बॉक्स -->
                <div class="map-box">
                    <div class="radar-pulse"></div>
                    <span style="z-index: 2; color: #fff; background: rgba(0,0,0,0.6); padding: 4px 8px; border-radius: 4px;">Live GPS Signal Tracking...</span>
                </div>
            </div>
        </div>

        <div class="footer">
            System Secure & Encrypted v2.4
        </div>
    </div>

    <script>
        // वीडियो रिकॉर्डिंग के दौरान अगर आप JavaScript से डायनामिक डेटा बदलना चाहें तो यहाँ बदल सकते हैं
        console.log("GPS Tracker Initialized Successfully.");
    </script>
</body>
</html>
